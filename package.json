{
  "name": "skins-pro",
  "version": "1.0.0",
  "description": "Skins Pro for Home Assistant",
  "main": "dist/skins-pro.js",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-skins.cjs && rollup -c",
    "watch": "rollup -c -w",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "type-check": "tsc --noEmit",
    "release": "npm run clean && npm run build"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "dashboard",
    "skins-pro",
    "multi-skin",
    "kiosk-mode"
  ],
  "author": "Skins Pro Contributors",
  "license": "UNLICENSED",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/node": "^20.10.5",
    "rollup": "^4.9.1",
    "sharp": "^0.35.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "lit": "^3.3.3"
  }
}
